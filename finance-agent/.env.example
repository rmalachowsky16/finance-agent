# ============================================================
# Finance Agent — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ------ Anthropic -----------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ------ Supabase ------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key

# ------ Upstash Redis -------------------------------------------
UPSTASH_REDIS_URL=https://your-instance.upstash.io
UPSTASH_REDIS_TOKEN=your-upstash-token

# ------ External Data Providers ---------------------------------
NEWSAPI_KEY=your-newsapi-key
FRED_API_KEY=your-fred-api-key

# ------ SEC EDGAR Identity (required by EDGAR fair-access policy)
# Use your real company name and a contact email.
EDGAR_COMPANY_NAME=FinanceAgent
EDGAR_EMAIL=you@example.com

# ------ Chunker Tuning (optional, defaults shown) ---------------
CHUNK_SIZE_TOKENS=3000
CHUNK_OVERLAP_TOKENS=200
